{
  "name": "signalk-ais-target-prioritizer",
  "version": "0.4.15",
  "description": "Plots and priorizes AIS targets according to guard and CPA criteria.",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-ais",
    "signalk-category-chart-plotters"
  ],
  "signalk-plugin-enabled-by-default": true,
  "signalk": {
    "appIcon": "./assets/icon-120.png",
    "displayName": "AIS Target Prioritizer",
    "screenshots": [
      "./resources/main.png",
      "./resources/vessel-properties.png",
      "./resources/vessel-table.png",
      "./resources/settings.png",
      "./resources/edit-profiles.png",
      "./resources/alarms.png"
    ],
    "recommends": [
      "@signalk/charts-plugin",
      "signalk-pmtiles-plugin"
    ]
  },
  "engines": {
    "note": "*** SHOULD SETUP CI TEST WITH NODE 18 + SK SERVER 2.13.5 ***",
    "node": ">=18"
  },
  "license": "MIT",
  "author": {
    "name": "Jeremy Waters",
    "email": "jaffadog@gmail.com"
  },
  "main": "plugin/index.cjs",
  "type": "commonjs",
  "files": [
    "plugin/",
    "public/",
    "resources/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaffadog/signalk-ais-target-prioritizer.git"
  },
  "bugs": {
    "url": "https://github.com/jaffadog/signalk-ais-target-prioritizer/issues"
  },
  "homepage": "https://github.com/jaffadog/signalk-ais-target-prioritizer",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:plugin": "rollup -c",
    "build:plugin:node18": "cross-env SKIP_VISUALIZER=1 NODE_OPTIONS=--experimental-global-webcrypto rollup -c",
    "build": "npm run build:web && npm run build:plugin",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.plugin.json",
    "format": "npx prettier . --write",
    "format:check": "npx prettier . --check",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "checks": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "preversion": "npm run checks",
    "changelog": "node scripts/generate-changelog.mjs",
    "version": "npm run changelog"
  },
  "dependencies": {
    "@lucide/svelte": "^1.24.0",
    "@protomaps/basemaps": "^5.7.2",
    "@turf/circle": "^7.3.5",
    "@turf/destination": "^7.3.5",
    "ky": "1.14.3",
    "maplibre-gl": "^5.24.0",
    "mmsi-country-lookup": "^1.0.2",
    "nosleep.js": "^0.12.0",
    "partysocket": "^1.3.0",
    "pmtiles": "^4.4.1",
    "tar": "^7.5.20"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@emnapi/wasi-threads": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@signalk/server-api": "^2.30.0",
    "@skeletonlabs/skeleton": "^4.15.2",
    "@skeletonlabs/skeleton-svelte": "^5.0.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "lucide-static": "^1.24.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rollup": "^4.62.2",
    "rollup-plugin-svelte": "^7.2.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "^5.56.4",
    "tailwindcss": "^4.3.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4"
  }
}
