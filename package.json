{
  "name": "signalk-ais-target-prioritizer",
  "private": true,
  "version": "0.4.0",
  "description": "A Signal K plugin that priorizes AIS targets according to guard and CPA criteria.",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-ais"
  ],
  "signalk-plugin-enabled-by-default": true,
  "signalk": {
    "appIcon": "./assets/icon-120.png",
    "displayName": "Signal K AIS Target Prioritizer"
  },
  "license": "MIT",
  "author": "Jeremy Waters <jaffadog@gmail.com>",
  "main": "plugin/index.cjs",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:plugin": "rollup -c",
    "build": "npm run build:web && npm run build:plugin",
    "preview": "vite preview",
    "format": "npx prettier . --write",
    "format:check": "npx prettier . --check",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@lucide/svelte": "^1.18.0",
    "@protomaps/basemaps": "^5.7.2",
    "@turf/circle": "^7.3.5",
    "@turf/destination": "^7.3.5",
    "ky": "^2.0.2",
    "maplibre-gl": "^5.24.0",
    "mmsi-country-lookup": "^1.0.2",
    "nosleep.js": "^0.12.0",
    "partysocket": "^1.2.0",
    "pmtiles": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@signalk/server-api": "^2.25.0",
    "@skeletonlabs/skeleton": "^4.15.2",
    "@skeletonlabs/skeleton-svelte": "^4.15.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rollup": "^4.62.0",
    "rollup-plugin-svelte": "^7.2.3",
    "svelte": "^5.56.3",
    "tailwindcss": "^4.3.1",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
