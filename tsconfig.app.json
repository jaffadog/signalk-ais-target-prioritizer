{
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "noEmit": true
  },
  "include": ["src/*.ts", "src/*.d.ts", "src/app/**/*", "src/engine/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "public",
    "plugin",
    ".svelte-kit",
    ".vite"
  ]
}
